generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  GROUP_MANAGER
  GENERAL_MANAGER
  STAFF_FRONTDESK
  STAFF_BAR
  MAINTENANCE
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  PENTHOUSE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum LogStatus {
  RESERVED
  ACTIVE
  CHECKED_OUT
  CANCELLED
}

enum LedgerType {
  CREDIT
  DEBIT
}

enum TransactionType {
  INCOME
  EXPENSE
  REFUND
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CHARGE_TO_ROOM
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum POSCategory {
  BAR
  RESTAURANT
  LAUNDRY
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── NEW: Hotel Group (Parent) ──────────────────────────────────────────────────
// A Group owns one or many Hotel subsidiaries. Data is strictly siloed per group.

model HotelGroup {
  id                   String    @id @default(cuid())
  name                 String
  logoUrl              String?
  subscriptionExpiry   DateTime?
  warningDays          Int       @default(14)   // days before expiry to trigger warning
  supportPhone         String?                  // visible only to GENERAL_MANAGERs of this group
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  hotels               Hotel[]
  subscriptions        Subscription[]
  users                User[]
}

// ── System Settings (Super Admin) ─────────────────────────────────────────────

model SystemSettings {
  id            String   @id @default(cuid())
  supportPhone  String?  // global fallback support phone set by SUPER_ADMIN
  updatedAt     DateTime @updatedAt
}

// ── User ──────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          Role      @default(STAFF_FRONTDESK)
  accessLevel   Int       @default(1)
  groupId       String?   // NEW: which group this user belongs to
  group         HotelGroup? @relation(fields: [groupId], references: [id])
  hotelId       String?
  hotel         Hotel?    @relation(fields: [hotelId], references: [id])
  inviteToken   String?   @unique
  inviteExpiry  DateTime?
  isVerified    Boolean   @default(false)
  isSuspended   Boolean   @default(false)
  passwordHash  String?
  // Forgot password — time-limited reset token
  resetToken        String?
  resetTokenExpiry  DateTime?
  // NDPA 2023 — privacy consent timestamp
  privacyConsentAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NEW: extra roles assigned by manager (for multi-role staff)
  extraRoles    UserExtraRole[]

  authenticators        Authenticator[]
  roomLogs              RoomLog[]
  maintenanceLogs       MaintenanceLog[] @relation("AssignedMaintenance")
  createdMaintenance    MaintenanceLog[] @relation("CreatedMaintenance")
  posSales              POSSale[]
  expenses              Expense[]        @relation("SubmittedExpenses")
  approvedExpenses      Expense[]        @relation("ApprovedExpenses")
  webauthnChallenge     WebAuthnChallenge?

  // Service request assignment
  assignedServiceRequests GuestServiceRequest[] @relation("AssignedServiceRequests")

  @@index([groupId])
  @@index([hotelId])
  @@index([role])
}

// ── NEW: Multi-Role Assignment ─────────────────────────────────────────────────
// Allows a single staff member to hold additional roles with togglable permissions.

model UserExtraRole {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role
  // JSON object of toggled feature flags, e.g. {"canCheckIn":true,"canProcessPos":false}
  permissions Json     @default("{}")
  assignedAt  DateTime @default(now())

  @@unique([userId, role])
}

// ── WebAuthn ──────────────────────────────────────────────────────────────────

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge String
  expiresAt DateTime // 5-minute window — prevents replay attacks
  createdAt DateTime @default(now())
}

model Authenticator {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID         String   @unique
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  deviceName           String?
  createdAt            DateTime @default(now())
}

// ── Hotel (Subsidiary) ────────────────────────────────────────────────────────

model Hotel {
  id          String      @id @default(cuid())
  groupId     String?     // NEW: parent group
  group       HotelGroup? @relation(fields: [groupId], references: [id])
  name        String
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  totalRooms  Int
  maxStaff    Int         @default(20)     // editable by manager and above
  vatPercent  Decimal     @default(7.5) @db.Decimal(5, 2)  // VAT rate for receipts; editable by manager
  currency    String      @default("NGN")
  timezone    String      @default("UTC")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  users           User[]
  rooms           Room[]
  roomLogs        RoomLog[]
  maintenanceLogs MaintenanceLog[]
  posSales        POSSale[]
  posInventory    POSInventory[]
  expenses        Expense[]
  stockIssuances  StockIssuance[]
  transactions    Transaction[]
  shifts          Shift[]
}

// ── Room ──────────────────────────────────────────────────────────────────────

model Room {
  id            String     @id @default(cuid())
  hotelId       String
  hotel         Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  number        String
  type          RoomType   @default(STANDARD)
  status        RoomStatus @default(AVAILABLE)
  pricePerNight Decimal    @db.Decimal(10, 2)
  floor         Int?
  description   String?
  customName    String?   // optional human name e.g. "Presidential Suite"
  amenities     String?
  maxOccupants  Int        @default(2)
  weekendRate   Decimal?   @db.Decimal(10, 2)  // optional weekend rate
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)  // e.g. 10 = 10% off
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  roomLogs        RoomLog[]
  maintenanceLogs MaintenanceLog[]

  @@unique([hotelId, number])
}

// ── RoomLog ───────────────────────────────────────────────────────────────────

model RoomLog {
  id            String    @id @default(cuid())
  hotelId       String
  hotel         Hotel     @relation(fields: [hotelId], references: [id])
  roomId        String
  room          Room      @relation(fields: [roomId], references: [id])
  guestName     String
  guestEmail    String?
  guestPhone    String?
  guestIdType   String?
  guestIdNumber String?
  checkInDate   DateTime
  checkOutDate  DateTime
  nights        Int
  ratePerNight  Decimal   @db.Decimal(10, 2)
  totalAmount   Decimal   @db.Decimal(10, 2)
  amountPaid    Decimal   @db.Decimal(10, 2) @default(0)
  balance       Decimal   @db.Decimal(10, 2) @default(0)
  status        LogStatus @default(ACTIVE)
  notes         String?
  createdById   String
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  checkedOutAt  DateTime?
  receiptSentAt DateTime?  // timestamp of last auto/manual receipt email

  transactions Transaction[]
  creditLedger GuestCreditLedger[]
  posSales     POSSale[]
  serviceRequests GuestServiceRequest[]
  feedback        GuestFeedback[]
  // QR Guest Portal
  isReservation Boolean  @default(false)  // true = future booking not yet active
  reservedUntil DateTime?               // auto-cancel reservation after this date if not checked in
  depositPaid   Decimal?  @db.Decimal(10, 2)  // deposit paid at reservation
  reservationRef String?                 // optional booking reference
  qrToken      String?   @unique  // unique token for guest portal URL
  // Soft delete — record hidden but recoverable
  deletedAt    DateTime?
  // NDPA 2023 — date after which guest PII should be anonymised (2 years from checkout)
  retainUntil  DateTime?
  @@index([hotelId])
  @@index([status])
  @@index([createdAt])
  @@index([hotelId, status])
  @@index([retainUntil])
}

model GuestCreditLedger {
  id          String     @id @default(cuid())
  roomLogId   String
  roomLog     RoomLog    @relation(fields: [roomLogId], references: [id])
  type        LedgerType
  amount      Decimal    @db.Decimal(10, 2)
  description String?
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
}

// ── Transaction ───────────────────────────────────────────────────────────────

model Transaction {
  id            String          @id @default(cuid())
  hotelId       String
  hotel         Hotel           @relation(fields: [hotelId], references: [id])
  roomLogId     String?
  roomLog       RoomLog?        @relation(fields: [roomLogId], references: [id])
  type          TransactionType
  category      String
  amount        Decimal         @db.Decimal(10, 2)
  description   String?
  reference     String?
  paymentMethod PaymentMethod   @default(CASH)
  createdAt     DateTime        @default(now())

  @@index([hotelId])
  @@index([createdAt])
  @@index([type])
  @@index([hotelId, createdAt])
}

// ── Maintenance ───────────────────────────────────────────────────────────────

model MaintenanceLog {
  id           String            @id @default(cuid())
  hotelId      String
  hotel        Hotel             @relation(fields: [hotelId], references: [id])
  roomId       String?
  room         Room?             @relation(fields: [roomId], references: [id])
  title        String
  description  String
  priority     Priority          @default(MEDIUM)
  status       MaintenanceStatus @default(OPEN)
  assignedToId String?
  assignedTo   User?             @relation("AssignedMaintenance", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User              @relation("CreatedMaintenance", fields: [createdById], references: [id])
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?
  updatedAt    DateTime          @updatedAt

  @@index([hotelId])
  @@index([status])
  @@index([assignedToId])
  @@index([hotelId, status])
}

// ── POS ───────────────────────────────────────────────────────────────────────

model POSSale {
  id          String        @id @default(cuid())
  hotelId     String
  hotel       Hotel         @relation(fields: [hotelId], references: [id])
  roomLogId   String?
  roomLog     RoomLog?      @relation(fields: [roomLogId], references: [id])
  chargedRoom String?
  items       POSSaleItem[]
  totalAmount Decimal       @db.Decimal(10, 2)
  paymentType PaymentMethod @default(CASH)
  staffId     String
  staff       User          @relation(fields: [staffId], references: [id])
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([hotelId])
  @@index([createdAt])
  @@index([staffId])
  @@index([hotelId, createdAt])
}

model POSSaleItem {
  id         String      @id @default(cuid())
  saleId     String
  sale       POSSale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  name       String
  category   POSCategory @default(BAR)
  quantity   Int
  unitPrice  Decimal     @db.Decimal(10, 2)
  totalPrice Decimal     @db.Decimal(10, 2)
}

model POSInventory {
  id           String      @id @default(cuid())
  hotelId      String
  hotel        Hotel       @relation(fields: [hotelId], references: [id])
  name         String
  category     POSCategory @default(BAR)
  price        Decimal     @db.Decimal(10, 2)
  stock        Int         @default(0)
  reorderLevel Int         @default(5)
  unit         String      @default("unit")
  isAvailable  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  issuances    StockIssuance[]

  @@index([hotelId])
  @@index([hotelId, category])
}

// ── Stock Issuance (Internal Use / Utility Transfer) ──────────────────────────
// Tracks inventory items issued for internal use (bar → kitchen, utilities, etc.)
model StockIssuance {
  id           String       @id @default(cuid())
  hotelId      String
  hotel        Hotel        @relation(fields: [hotelId], references: [id])
  inventoryId  String
  inventory    POSInventory @relation(fields: [inventoryId], references: [id])
  quantity     Int
  issuedToName String       // Name of person/dept receiving
  purpose      String       // e.g. "Kitchen use", "Housekeeping", "Bar transfer"
  category     String       @default("INTERNAL_USE") // INTERNAL_USE | BAR_TRANSFER | KITCHEN | HOUSEKEEPING | MAINTENANCE | OTHER
  notes        String?
  issuedById   String
  issuedBy     User         @relation(fields: [issuedById], references: [id])
  stockBefore  Int          // stock level before issuance
  stockAfter   Int          // stock level after issuance
  createdAt    DateTime     @default(now())

  @@index([hotelId])
  @@index([inventoryId])
  @@index([issuedById])
  @@index([hotelId, createdAt])
}

// ── Expense ───────────────────────────────────────────────────────────────────

model Expense {
  id            String        @id @default(cuid())
  hotelId       String
  hotel         Hotel         @relation(fields: [hotelId], references: [id])
  title         String
  amount        Decimal       @db.Decimal(10, 2)
  category      String
  status        ExpenseStatus @default(PENDING)
  submittedById String
  submittedBy   User          @relation("SubmittedExpenses", fields: [submittedById], references: [id])
  approvedById  String?
  approvedBy    User?         @relation("ApprovedExpenses", fields: [approvedById], references: [id])
  notes         String?
  receiptUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([hotelId])
  @@index([status])
  @@index([submittedById])
  @@index([hotelId, status])
}

// ── Audit Log (NDPA 2023 + Accountability) ────────────────────────────────────
// Records all critical actions: check-in, checkout, expense approval,
// password reset, user invite, role change, room delete, price change

model AuditLog {
  id          String   @id @default(cuid())
  userId      String                          // who performed the action
  userName    String                          // denormalised for reporting
  userRole    String                          // denormalised for reporting
  hotelId     String?                         // which hotel (null for system actions)
  action      String                          // e.g. CHECK_IN, CHECKOUT, EXPENSE_APPROVED
  entityType  String                          // e.g. RoomLog, Expense, User
  entityId    String?                         // ID of the affected record
  description String                          // human-readable summary
  oldValue    Json?                           // before state (for edits)
  newValue    Json?                           // after state (for edits)
  ipAddress   String?                         // request IP
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([hotelId])
  @@index([action])
  @@index([createdAt])
  @@index([hotelId, createdAt])
}

// ── Guest Portal / QR System ──────────────────────────────────────────────────
model GuestServiceRequest {
  id          String   @id @default(cuid())
  roomLogId   String
  roomLog     RoomLog  @relation(fields: [roomLogId], references: [id])
  hotelId     String
  type        String   // FOOD_ORDER, DRINK_ORDER, HOUSEKEEPING, MAINTENANCE, CHECKOUT_REQUEST, OTHER
  items       Json?    // array of {name, qty, price} for food/drink orders
  notes       String?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  totalAmount Decimal? @db.Decimal(10, 2)
  // Staff assignment + response time tracking
  assignedToId    String?
  assignedTo      User?     @relation("AssignedServiceRequests", fields: [assignedToId], references: [id])
  assignedAt      DateTime?
  startedAt       DateTime? // when status → IN_PROGRESS
  completedAt     DateTime? // when status → COMPLETED
  responseMinutes Int?      // computed: completedAt - createdAt in minutes
  // Guest feedback on this specific request
  guestRating     Int?      // 1-5 stars (optional, submitted via QR portal)
  guestComment    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomLogId])
  @@index([hotelId])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

// ── Guest Feedback ────────────────────────────────────────────────────────────
model GuestFeedback {
  id            String   @id @default(cuid())
  roomLogId     String
  roomLog       RoomLog  @relation(fields: [roomLogId], references: [id])
  hotelId       String
  // Overall stay rating (shown at checkout)
  overallRating Int?     // 1-5 stars
  overallComment String?
  // Per-service rating (shown after service request is completed)
  serviceRequestId String?
  serviceRating    Int?     // 1-5 stars
  serviceComment   String?
  createdAt     DateTime @default(now())

  @@index([hotelId])
  @@index([roomLogId])
  @@index([createdAt])
}

// ── Subscription / Billing ─────────────────────────────────────────────────────
model Subscription {
  id              String    @id @default(cuid())
  groupId         String
  group           HotelGroup @relation(fields: [groupId], references: [id])
  plan            String    // "MONTHLY" | "YEARLY"
  amountNgn       Decimal   @db.Decimal(12, 2)
  status          String    @default("ACTIVE")   // ACTIVE | EXPIRED | SUSPENDED | CANCELLED
  startDate       DateTime
  endDate         DateTime
  autoRenew       Boolean   @default(true)
  notes           String?
  createdBy       String?   // userId of super admin who set it
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([groupId])
  @@index([endDate])
  @@index([status])
}

// ── Staff Shift / Handover ─────────────────────────────────────────────────────
model Shift {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id])
  openedById    String
  closedById    String?
  openedAt      DateTime @default(now())
  closedAt      DateTime?
  status        String   @default("OPEN")  // OPEN | CLOSED
  // Summary snapshot at shift close
  totalCheckIns   Int     @default(0)
  totalCheckOuts  Int     @default(0)
  totalRevenue    Decimal @default(0) @db.Decimal(12, 2)
  totalPosRevenue Decimal @default(0) @db.Decimal(12, 2)
  totalExpenses   Decimal @default(0) @db.Decimal(12, 2)
  openRoomsCount  Int     @default(0)
  pendingBalance  Decimal @default(0) @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([hotelId])
  @@index([status])
  @@index([hotelId, status])
}

// ── In-App Notification ────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  hotelId   String
  userId    String?  // null = broadcast to all hotel staff
  type      String   // LOW_STOCK | OVERDUE_CHECKOUT | MAINTENANCE_ESCALATED | SUBSCRIPTION_EXPIRY | SHIFT_OPENED | SHIFT_CLOSED
  title     String
  message   String
  isRead    Boolean  @default(false)
  entityId  String?  // related record ID
  createdAt DateTime @default(now())

  @@index([hotelId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
